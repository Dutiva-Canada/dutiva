# Copy this file to .env.local and fill in your values.
# Server-side variables (HUGGINGFACE_API_KEY, BRAVE_SEARCH_API_KEY) must be
# set in Vercel project settings — they are never exposed to the browser.

# ── Supabase (required) ───────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-publishable-key
VITE_SITE_URL=https://dutiva.ca

# Optional fallback if your dashboard labels the browser key as "anon key".
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional explicit magic-link return URL if you want to override VITE_SITE_URL.
# VITE_AUTH_REDIRECT_URL=https://dutiva.ca/auth

# ── AI Advisor (server-side, set in Vercel project settings) ──────────────────
# Hugging Face token — free from https://huggingface.co/settings/tokens
# Used to call Mistral-7B-Instruct-v0.3 via the HF Inference API.
HUGGINGFACE_API_KEY=hf_...

# Brave Search API key — free tier at https://brave.com/search/api
# Provides up to 2,000 web search queries per month at no cost.
# The advisor uses this to ground answers about recent legislative changes.
BRAVE_SEARCH_API_KEY=BSA...
